<?xml version="1.0" encoding="utf-8"?>
<full-backup-content xmlns:android="http://schemas.android.com/apk/res/android">



    <!-- Include important app directories -->
    <include
        domain="database"
        path="meadow_database.db" />

    <include
        domain="sharedpref"
        path="datastore_preferences.xml" />

    <include
        domain="files"
        path="projects/" />
    <include
        domain="files"
        path="scripts/" />

    <!-- Exclude temporary and volatile data -->
    <exclude
        domain="cache"
        path="." />

    <exclude
        domain="files"
        path="temp/" />
</full-backup-content>